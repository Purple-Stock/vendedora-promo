{
  "name": "vendedora-promo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev": "npx serve . -p 3456",
    "verify": "npm run format:check && npm run lint && npm test && npm run test:e2e"
  },
  "lint-staged": {
    "*.{js,json,html,md}": "prettier --write",
    "*.js": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "serve": "^14.2.4",
    "vitest": "^3.2.4"
  }
}
